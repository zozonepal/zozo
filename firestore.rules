rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all safety net for any other paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        request.auth.token.email == "zozonepal5@gmail.com" ||
        request.auth.token.email == "fitoorbhandari38@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 1. Products Collection Rules
    match /products/{productId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // 2. Transactions (Customer Orders) Rules
    match /transactions/{transactionId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    // 3. Settings Collection Rules
    match /settings/{settingsId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // 4. Promos Rules
    match /promos/{promoId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // 5. Banners Rules
    match /banners/{bannerId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // 6. FAQs Rules
    match /faqs/{faqId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // 7. Admins Rules
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // 8. Reviews Rules
    match /reviews/{reviewId} {
      allow read, list, create: if true;
      allow update, delete: if isAdmin();
    }

    // 9. Categories Rules
    match /categories/{categoryId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }
  }
}
